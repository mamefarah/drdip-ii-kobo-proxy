{
  "version": 2,
  "buildCommand": "echo 'No build needed'",
  "outputDirectory": ".",
  "functions": {
    "api/*.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/kobo-proxy(.*)",
      "dest": "/api/kobo-proxy.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
